<style>
  :root{--bg:#06080d;--card:rgba(18,24,33,.55);--line:#1d2734;--ink:#e6e6e6;--mut:#8b949e;--accent:#58a6ff;--cyan:#45c9e0}
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{margin:0;background:#06080d;color:var(--ink);font-family:-apple-system,Segoe UI,Arial,sans-serif;overflow-x:hidden}
  /* ---- deep space backdrop ---- */
  .sky{position:fixed;inset:0;z-index:-1;overflow:hidden;background:radial-gradient(130% 90% at 50% -10%,#0b1626,#070a10 55%,#05070b)}
  .sky .neb{position:absolute;inset:0;background:radial-gradient(38% 30% at 80% 8%,rgba(69,201,224,.14),transparent 70%),radial-gradient(42% 34% at 8% 96%,rgba(150,120,255,.12),transparent 70%);animation:neb 16s ease-in-out infinite}
  @keyframes neb{50%{opacity:.55}}
  .sky .stars{position:absolute;inset:-60px;background-repeat:repeat;opacity:.78;background-size:340px 240px;animation:tw 4.5s ease-in-out infinite;
    background-image:radial-gradient(2px 2px at 30px 40px,#fff,transparent),radial-gradient(1px 1px at 130px 90px,#bfe,transparent),radial-gradient(1.6px 1.6px at 220px 50px,#fff,transparent),radial-gradient(1px 1px at 300px 130px,#9cf,transparent),radial-gradient(2px 2px at 80px 170px,#fff,transparent),radial-gradient(1px 1px at 360px 30px,#cff,transparent),radial-gradient(1px 1px at 180px 210px,#fff,transparent)}
  .sky .stars.s2{background-size:520px 360px;opacity:.5;animation:drift 80s linear infinite,tw 7s ease-in-out infinite}
  .sky .stars.s3{background-size:680px 480px;opacity:.4;animation:drift2 150s linear infinite,tw 9s ease-in-out infinite;
    background-image:radial-gradient(1.4px 1.4px at 60px 120px,#fff,transparent),radial-gradient(1px 1px at 260px 60px,#adf,transparent),radial-gradient(1.2px 1.2px at 420px 200px,#fff,transparent),radial-gradient(1px 1px at 520px 90px,#cff,transparent),radial-gradient(2px 2px at 160px 320px,#fff,transparent),radial-gradient(1px 1px at 600px 380px,#fff,transparent)}
  @keyframes drift2{to{background-position:-680px 0}}
  .sky .spk{position:absolute;width:16px;height:16px;background:radial-gradient(circle,rgba(255,255,255,.85),transparent 38%);animation:spk var(--d,4s) ease-in-out infinite}
  .sky .spk::before,.sky .spk::after{content:"";position:absolute;left:50%;top:50%;background:linear-gradient(transparent,rgba(200,240,255,.95),transparent)}
  .sky .spk::before{width:1.4px;height:18px;transform:translate(-50%,-50%)}
  .sky .spk::after{height:1.4px;width:18px;transform:translate(-50%,-50%)}
  @keyframes spk{0%,100%{opacity:.18;transform:scale(.55)}50%{opacity:1;transform:scale(1)}}
  .sky .shoot{position:absolute;width:150px;height:2px;border-radius:2px;background:linear-gradient(90deg,rgba(255,255,255,0),#fff);filter:drop-shadow(0 0 6px #cfe);opacity:0;animation:shoot 12s linear infinite}
  .sky .shoot.b{top:58%;left:42%;animation-delay:7s;animation-duration:16s}
  @keyframes shoot{0%{opacity:0;transform:translate(-180px,-80px) rotate(20deg)}5%{opacity:.95}15%{opacity:.95}21%{opacity:0;transform:translate(560px,220px) rotate(20deg)}100%{opacity:0}}
  .moonbg{position:absolute;top:-92px;right:-72px;width:480px;height:480px;border-radius:50%;
    background:url('moon_bg.png') center/contain no-repeat;
    filter:drop-shadow(0 0 52px rgba(150,190,255,.22));opacity:.96;animation:moonfloat 28s ease-in-out infinite}
  @keyframes moonfloat{50%{transform:translateY(12px)}}
  @keyframes tw{50%{opacity:.25}}
  @keyframes drift{to{background-position:560px 0}}
  /* ---- header ---- */
  header.shdr{--cyan:#2e74c0;position:relative;display:flex;align-items:center;gap:16px;margin:16px 18px 0;padding:14px 22px;
    background:rgba(10,13,18,.5);backdrop-filter:blur(8px);border:1px solid var(--line);border-top:2px solid var(--cyan);border-radius:12px;overflow:hidden}
  .shdr::before{content:"";position:absolute;top:9px;left:9px;width:14px;height:14px;border-top:2px solid var(--cyan);border-left:2px solid var(--cyan);opacity:.55}
  .shdr .mark{width:60px;height:60px;flex:0 0 auto;background:center/contain no-repeat url('shoppa_mark.png');filter:drop-shadow(0 0 3px rgba(60,125,205,.5));animation:pulse 3.4s ease-in-out infinite}
  @keyframes pulse{50%{filter:drop-shadow(0 0 7px rgba(60,125,205,.85))}}
  .shdr .eyebrow{font:600 12px ui-monospace,Consolas,monospace;letter-spacing:.24em;color:var(--mut)}
  .shdr .htitle{font:800 25px ui-monospace,Consolas,monospace;letter-spacing:.02em;margin:3px 0}
  .shdr .htitle span{color:var(--cyan)}
  .shdr .hsub{font:600 12px ui-monospace,Consolas,monospace;letter-spacing:.16em;color:var(--mut)}
  .shdr .status{margin-left:auto;align-self:flex-start;display:flex;align-items:center;gap:6px;font:600 12px ui-monospace,monospace;letter-spacing:.12em;color:var(--cyan);border:1px solid #2a5a92;border-radius:6px;padding:4px 10px}
  .shdr .status i{width:6px;height:6px;border-radius:50%;background:var(--cyan);box-shadow:0 0 8px var(--cyan);animation:tw 1.6s infinite}
  /* ---- ticker ---- */
  .ticker{overflow:hidden;border-top:1px solid #16202c;border-bottom:1px solid #16202c;background:rgba(8,11,16,.55);height:30px;margin:12px 0 0}
  .ticker .tk{display:flex;gap:28px;white-space:nowrap;width:max-content;line-height:30px;font:600 12px ui-monospace,monospace;color:#7d8896;animation:tkm 26s linear infinite;padding-left:18px}
  .ticker b{color:#e6e6e6}.up{color:#3fb950!important}.dn{color:#e2554b!important}.warn{color:#e0a23f!important}
  @keyframes tkm{to{transform:translateX(-50%)}}
  /* ---- orbital solar system ---- */
  .hero{position:relative;display:flex;flex-direction:column;align-items:center;padding:10px 0 0}
  .system{position:relative;display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding:8px 12px;width:100%;max-width:1720px;margin:0 auto}
  @keyframes spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
  @keyframes spinr{to{transform:translate(-50%,-50%) rotate(-360deg)}}
  .cluster{position:relative;display:flex;align-items:center;justify-content:center;cursor:pointer;flex:0 0 auto}
  .cluster.big{width:460px;height:460px}.cluster.med{width:300px;height:300px}
  .orb{position:absolute;top:50%;left:50%;border-radius:50%;transform:translate(-50%,-50%);pointer-events:none;border:1px solid rgba(130,160,190,.16);animation:spin var(--sp,24s) linear infinite}
  .orb.rev{animation-name:spinr}
  .cluster:hover .orb{animation-play-state:paused}
  .mh{position:absolute;inset:0;transform:rotate(var(--a))}
  .moon{position:absolute;top:calc(var(--ms,9px)/-2);left:50%;margin-left:calc(var(--ms,9px)/-2);width:var(--ms,9px);height:var(--ms,9px);border-radius:50%;background:var(--mc);box-shadow:0 0 10px var(--mc),0 0 3px #fff}
  .mh:nth-child(3n) .moon{--ms:13px}
  .mh:nth-child(4n) .moon{--ms:6px}
  .mh:nth-child(5n) .moon{--ms:11px;background:#fff;box-shadow:0 0 10px var(--mc),0 0 4px #fff}
  .amoon{position:absolute;top:-9px;left:50%;margin-left:-9px;width:18px;height:18px;border-radius:50%;background:var(--mc);box-shadow:0 0 11px var(--mc),0 0 3px #fff;pointer-events:auto;cursor:pointer;transition:transform .12s,box-shadow .12s}
  .amoon:hover{transform:scale(1.55);box-shadow:0 0 18px #fff,0 0 9px var(--mc);z-index:6}
  .amoon .gw{position:absolute;inset:0;display:grid;place-items:center;animation:cspin var(--sp,24s) linear infinite}
  @keyframes cspin{to{transform:rotate(-360deg)}}
  .amoon .glyph{font:700 12px ui-monospace,Consolas,monospace;color:#06121c;transform:rotate(calc(-1 * var(--a)));transform-origin:center;line-height:1}
  .cluster:hover .gw{animation-play-state:paused}
  #cap.on{color:#dff}
  .pring{position:absolute;top:50%;left:50%;border-radius:50%;border:2px solid rgba(120,184,255,.55);box-shadow:0 0 16px rgba(88,166,255,.28);transform:translate(-50%,-50%) rotate(-22deg);pointer-events:none}
  .pring.a{width:260px;height:80px;z-index:4}
  .pring.b{width:320px;height:108px;border-width:1px;border-color:rgba(159,233,245,.3);z-index:2}
  .ell{position:absolute;inset:0;transform:rotate(-20deg) scaleX(1.6);pointer-events:none}
  .planet{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;z-index:3;
    font:800 12px ui-monospace,monospace;letter-spacing:.08em;color:#fff;text-shadow:0 1px 4px #000,0 0 9px rgba(0,0,0,.85);transition:transform .2s,box-shadow .2s}
  .planet small{font-weight:600;font-size:12px;letter-spacing:.1em;color:#9fb6c8;margin-top:4px}
  .planet::after{content:"";position:absolute;inset:-7px;border-radius:50%;background:radial-gradient(circle,var(--pg),transparent 70%);animation:tw 3s ease-in-out infinite;z-index:-1}
  .cluster.big .planet{width:158px;height:158px;font-size:14px}
  .cluster.med .planet{width:158px;height:158px;font-size:14px}
  .cluster:hover .planet{transform:translate(-50%,-50%) scale(1.06);box-shadow:0 0 34px var(--pg)}
  .cluster.active .planet{box-shadow:0 0 0 2px var(--pc),0 0 30px var(--pg)}
  .pr{--pc:#45c9e0;--pg:rgba(69,201,224,.55)}.pr .planet{border:1px solid #a98c54;background:radial-gradient(circle at 36% 30%,rgba(255,238,205,.22),rgba(255,238,205,0) 46%),linear-gradient(-26deg,rgba(18,12,5,0) 0%,rgba(18,12,5,.34) 16%,rgba(122,94,58,0) 30%,rgba(18,12,5,.3) 51%,rgba(122,94,58,.12) 69%,rgba(18,12,5,0) 100%),linear-gradient(-16deg,#5e4828 0%,#6f5533 4%,#4a3a20 9%,#6b5230 12%,#3a2c16 17%,#785c38 23%,#534025 27%,#6e5532 33%,#42331b 38%,#735738 44%,#50402a 49%,#382a14 54%,#6b5230 60%,#574326 65%,#785c38 72%,#463618 78%,#6e5532 85%,#503e22 92%,#5a4527 100%),radial-gradient(circle,#5e4823,#2c2110);box-shadow:inset -16px -18px 42px 7px rgba(14,9,3,.78),inset 8px 10px 18px rgba(255,236,200,.09)}
  .pc{--pc:#7ee787;--pg:rgba(126,231,135,.5)}.pc .planet{border:1px solid #7ee787;background:#05070b url('tag_commodities.png') center/cover;box-shadow:inset 0 0 20px 6px rgba(4,8,16,.6)}
  .pl{--pc:#3461c4;--pg:rgba(52,97,196,.5)}.pl .planet{border:1px solid #3461c4;background:#05070b url('tag_tradelab.png') center/cover;box-shadow:inset 0 0 20px 6px rgba(4,8,16,.6)}
  .hint{font:700 12px ui-monospace,monospace;letter-spacing:.22em;color:#7c91a6;margin:48px 0 2px;text-align:center}
  .legend{display:flex;justify-content:space-between;gap:36px 48px;flex-wrap:wrap;align-items:flex-start;margin:48px auto 0;max-width:1480px;padding:0 40px}
  .lgrp h5{font:700 12px ui-monospace,monospace;letter-spacing:.14em;color:var(--mut);margin:0 0 7px;display:flex;align-items:center;gap:7px}
  .lgrp h5 i{width:8px;height:8px;border-radius:50%;background:var(--c);box-shadow:0 0 8px var(--c)}
  .lgrp ul{list-style:none;margin:0;padding:0;font:400 14px -apple-system,Segoe UI,Arial;max-width:220px}
  .lgrp.two{grid-column:span 2}
  .lgrp.two ul{display:grid;grid-template-columns:1fr 1fr;column-gap:16px;align-items:start;max-width:340px}
  .lgrp li{color:#9fb2c4;line-height:1.5;display:flex;flex-wrap:wrap;align-items:center}
  .lgrp li b{color:#cfe;font-family:ui-monospace,Consolas,monospace;display:inline-block;width:15px;text-align:center;margin-right:4px}
  .lgrp a{color:inherit;text-decoration:none;flex:0 1 auto;white-space:nowrap;border-radius:6px;padding:0 4px;transition:.12s}
  .lgrp a:hover{color:#fff;background:rgba(255,255,255,.05)}
  .lgrp a:hover b{color:#fff;text-shadow:0 0 9px var(--c)}
  .lchev{flex:0 0 auto;background:none;border:0;color:#5f7186;cursor:pointer;padding:0;margin-left:5px;display:inline-flex;align-items:center;line-height:1}
  .lchev:hover,.lchev.open{color:var(--accent)}
  .lchev svg{width:9px;height:9px;transition:transform .15s}
  .lchev.open svg{transform:rotate(180deg)}
  .ldesc{flex:0 0 100%;max-height:0;overflow:hidden;opacity:0;transition:.18s;color:var(--mut);font-size:12px;line-height:1.45}
  .ldesc.open{max-height:160px;opacity:1;margin:2px 0 6px}
  .amoon.lit{transform:scale(1.95);box-shadow:0 0 26px #fff,0 0 13px var(--mc);z-index:8}
  .cluster.frozen .orb,.cluster.frozen .gw{animation-play-state:paused}
  .prevcard{position:fixed;z-index:50;width:240px;pointer-events:none;opacity:0;transform:translateY(6px);transition:opacity .12s,transform .12s;background:rgba(13,18,26,.97);border:1px solid var(--accent);border-radius:12px;overflow:hidden;box-shadow:0 16px 42px rgba(0,0,0,.6),0 0 22px rgba(88,166,255,.28)}
  .prevcard.on{opacity:1;transform:none}
  .prevcard .pimg{height:120px;background:#0b0e13 center/cover no-repeat;border-bottom:1px solid var(--line)}
  .prevcard .pttl{font:600 13px -apple-system,Segoe UI,Arial;color:var(--ink);padding:9px 12px 0}
  .prevcard .pds{font:400 12px -apple-system,Segoe UI,Arial;color:var(--mut);padding:4px 12px 11px;line-height:1.45}
  /* ---- collapsible app panels ---- */
  .apppanel{display:none;animation:fade .3s ease;scroll-margin-top:14px}
  .apppanel.show{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  /* ---- sections ---- */
  main{max-width:none;margin:0;padding:18px 18px 60px}
  h2{font-size:12px;color:#9fb2c4;text-transform:uppercase;letter-spacing:.18em;margin:34px 0 12px;scroll-margin-top:14px;display:flex;align-items:center;gap:10px}
  h2::before{content:"";width:20px;height:2px;background:linear-gradient(90deg,var(--cyan),transparent);box-shadow:0 0 8px var(--cyan)}
  h2 span{letter-spacing:.04em}
  .lead{margin:0 0 12px;color:var(--mut);font-size:12.5px;line-height:1.5}
  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:34px 22px;margin:8px 0}
  .gal{display:grid;grid-template-columns:repeat(3,1fr);gap:34px 22px;margin:8px 0}
  .grid.duo{grid-template-columns:repeat(2,calc((100% - 44px)/3));justify-content:center}
  /* ---- glass tiles ---- */
  .tile{position:relative;background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden;
    display:flex;flex-direction:column;backdrop-filter:blur(6px);transition:transform .2s,box-shadow .2s,border-color .2s}
  .tile::after{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(88,166,255,.55),transparent);opacity:.6;z-index:3}
  .tile:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:0 14px 32px rgba(0,0,0,.55),0 0 22px rgba(88,166,255,.25)}
  .tile .thumb{display:block;height:220px;border-bottom:1px solid var(--line);background-color:#0b0e13;
    background-repeat:no-repeat;background-position:center;background-size:cover;transition:transform .3s;
    background-image:var(--img,url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg'/>")),url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='90'><defs><linearGradient id='g' x1='0' y1='0' x2='0' y2='1'><stop offset='0' stop-color='%2358a6ff' stop-opacity='.30'/><stop offset='1' stop-color='%2358a6ff' stop-opacity='0'/></linearGradient></defs><polygon points='0,90 0,68 24,62 48,72 72,44 96,54 120,30 144,42 168,20 192,30 216,12 240,22 240,90' fill='url(%23g)'/><polyline points='0,68 24,62 48,72 72,44 96,54 120,30 144,42 168,20 192,30 216,12 240,22' fill='none' stroke='%2358a6ff' stroke-width='3'/></svg>")}
  .tile:hover .thumb{transform:scale(1.05)}
  .tbody{padding:11px 13px}
  .trow{display:flex;align-items:center;gap:8px}
  .ttitle{font:600 14.5px -apple-system,Segoe UI,Arial;color:var(--ink);text-decoration:none;line-height:1.25}
  .ttitle:hover{color:var(--accent)}
  .pill{font-size:12px;border-radius:10px;padding:1px 8px;font-weight:700;letter-spacing:.04em;flex:0 0 auto}
  .new{background:var(--accent);color:#06080d}
  .live{background:#1f6f43;color:#d8ffe9}
  .report{background:#30363d;color:#adbac7}
  .chev{margin-left:auto;flex:0 0 auto;background:none;border:1px solid var(--line);border-radius:7px;
    color:var(--mut);width:28px;height:24px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.15s}
  .chev:hover{border-color:var(--accent);color:var(--accent)}
  .chev.open{color:var(--accent);border-color:#2d4a63}
  .chev svg{transition:transform .18s}
  .chev.open svg{transform:rotate(180deg)}
  .tdesc{max-height:0;overflow:hidden;opacity:0;transition:.2s;color:var(--mut);font:400 12px -apple-system,Segoe UI,Arial;line-height:1.5}
  .tdesc.open{max-height:280px;opacity:1;margin-top:9px}
  .tdesc a{color:var(--accent)}
  footer{color:var(--mut);font-size:12px;text-align:center;padding:24px;border-top:1px solid var(--line)}
  @media (prefers-reduced-motion:reduce){*{animation:none!important}}
</style>

